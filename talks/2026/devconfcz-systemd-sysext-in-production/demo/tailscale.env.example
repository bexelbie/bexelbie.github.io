# ABOUTME: Tailscale auth key for the demo control plane.
# ABOUTME: Copy to tailscale.env and fill in your key before running setup.sh.

# Generate an auth key at https://login.tailscale.com/admin/settings/keys
# Use an ephemeral, reusable key so the CP node auto-expires when deleted.
TS_KEY="tskey-auth-XXXX"
