# ABOUTME: Shared configuration for the devconf-sysext-demo Azure demo.
# ABOUTME: Edit STORAGE_ACCOUNT (must be globally unique) before running prep-infra.sh.

# -----------------------------------------------------------------------
# Azure resource groups
#   infra: persistent — storage account + FCoOS managed image
#   vms:   ephemeral  — VNet, NSG, all 4 VMs
# -----------------------------------------------------------------------
AZ_LOCATION="westeurope"
AZ_RG_INFRA="devconf-sysext-infra"
AZ_RG_VMS="devconf-sysext-vms-bex"

# Storage account name must be 3-24 chars, lowercase alphanumeric, globally unique.
STORAGE_ACCOUNT="bexdevconfsysext"
STORAGE_CONTAINER="sysexts"

# -----------------------------------------------------------------------
# Networking
# -----------------------------------------------------------------------
VNET_NAME="demo-vnet"
VNET_CIDR="10.55.0.0/16"
SUBNET_NAME="demo-subnet"
SUBNET_CIDR="10.55.0.0/24"
NSG_NAME="demo-nsg"

# -----------------------------------------------------------------------
# VMs
# -----------------------------------------------------------------------
VM_SIZE="Standard_B2ms"

# Flatcar marketplace image — marketplace terms are auto-accepted in setup.sh
FLATCAR_IMAGE="kinvolk:flatcar-container-linux-free:stable-gen2:4593.2.0"

# FCoOS managed image created by prep-infra.sh (stays in AZ_RG_INFRA)
FCOS_IMAGE_NAME="fcos-44-azure"

# VM names
CP_VM_NAME="flatcar-cp"
WORKER1_VM_NAME="worker-1"
WORKER2_VM_NAME="worker-2"
WORKER3_VM_NAME="worker-3"

ADMIN_USER="core"

# -----------------------------------------------------------------------
# FCoOS VHD download (used by prep-infra.sh)
# -----------------------------------------------------------------------
FCOS_VERSION="44.20260523.3.1"
FCOS_VHD_URL="https://builds.coreos.fedoraproject.org/prod/streams/stable/builds/${FCOS_VERSION}/x86_64/fedora-coreos-${FCOS_VERSION}-azure.x86_64.vhd.xz"
FCOS_VHD_SHA256="09f6663c645e43d97b97ef50547f804bb35443d8e74a9c8bb4969a0a02168520"

# -----------------------------------------------------------------------
# SSH
# -----------------------------------------------------------------------
SSH_KEY_PATH="${SSH_KEY_PATH:-$HOME/.ssh/id_ed25519}"
SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -o IdentitiesOnly=yes -i ${SSH_KEY_PATH}"

# -----------------------------------------------------------------------
# Local paths (derived — do not edit)
# -----------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JOIN_INFO="${SCRIPT_DIR}/join-info.env"
TOKEN_FILE="${SCRIPT_DIR}/headlamp-token"
