# ABOUTME: Shared configuration for the coreos-demo local experiment.
# ABOUTME: Defines IPs, image paths, and SSH options for QEMU-based VMs.

# Network (uses libvirt default bridge virbr0, 192.168.122.0/24)
CP_IP="192.168.122.10"
W1_IP="192.168.122.11"
W2_IP="192.168.122.12"
W3_IP="192.168.122.13"
GATEWAY="192.168.122.1"

# Hostnames
CP_HOSTNAME="flatcar-cp"
W1_HOSTNAME="worker-1"
W2_HOSTNAME="worker-2"
W3_HOSTNAME="worker-3"

# All VMs use the same admin user
ADMIN="core"

# Kubernetes sysext version (must match control-plane.bu and worker-1.bu)
K8S_SYSEXT="kubernetes-v1.33.2-x86-64"

SSH_KEY_PATH="${SSH_KEY_PATH:-$HOME/.ssh/id_ed25519}"
SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -o IdentitiesOnly=yes -i ${SSH_KEY_PATH}"

DEMO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IMAGES_DIR="${DEMO_DIR}/images"
IGN_DIR="${DEMO_DIR}/ignition"
PID_DIR="${DEMO_DIR}/pids"
LOG_DIR="${DEMO_DIR}/logs"
JOIN_INFO="${DEMO_DIR}/join-info.env"
TOKEN_FILE="${DEMO_DIR}/headlamp-token"

# Local file server for sysext caching (avoids internet downloads during demo runs)
FILESERVER_IP="192.168.122.1"   # virbr0 — reachable from all VMs
FILESERVER_PORT="8080"
SYSEXT_CACHE_DIR="${DEMO_DIR}/sysext-cache"
