# ABOUTME: Shared configuration for all scripts.
# ABOUTME: Defines Azure resource names, region, VM sizes, and SSH options.

RESOURCE_GROUP="kcd-flatcar-demo"
LOCATION="westeurope"
VNET_NAME="kcd-vnet"
VNET_CIDR="10.55.0.0/24"
SUBNET_NAME="kcd-subnet"
SUBNET_CIDR="10.55.0.0/24"
NSG_NAME="kcd-nsg"

CP_VM_NAME="flatcar-cp"
WORKER1_VM_NAME="flatcar-worker-1"
WORKER2_VM_NAME="flatcar-worker-2"

VM_SIZE="Standard_B2ms"
FLATCAR_IMAGE="kinvolk:flatcar-container-linux-free:stable-gen2:4593.2.0"
ADMIN_USER="core"

SSH_KEY_PATH="${SSH_KEY_PATH:-$HOME/.ssh/id_ed25519}"
SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -o IdentitiesOnly=yes -i ${SSH_KEY_PATH}"

COMMON_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
